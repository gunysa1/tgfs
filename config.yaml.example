telegram:
  bot_token: "YOUR_BOT_TOKEN_HERE"

mount:
  path: /mnt/tgfs

db:
  path: /var/lib/tgfs/tgfs.db

cache:
  max_size_gb: 2

chunk:
  # Telegram Bot API caps uploads at 50 MB per request.
  size_mb: 45

migrate:
  # Concurrent files in flight.
  file_workers: 4
  # Concurrent chunks per file.
  chunk_workers: 4
